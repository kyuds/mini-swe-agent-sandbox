# Env for the mini-swe-agent TRAINING run (scripts/mini_swe_agent/run_mini_swe_agent_sandbox.sh).
# Training hosts the policy model on YOUR OWN vLLM (H100s) via SkyRL's in-process inference engine,
# which exposes an OpenAI-compatible HTTP endpoint. The generator (with an empty
# miniswe_litellm_model_name) calls litellm `openai/<model.path>`, and litellm's openai provider routes
# to OPENAI_BASE_URL below = that local vLLM. So OPENAI_BASE_URL is REQUIRED for training; keep it.
#
# The no-GPU GENERATION demo does NOT use this file -- it uses litellm's native fireworks_ai provider
# (FIREWORKS_AI_API_KEY); see scripts/mini_swe_agent/run_generate_fireworks.sh.

OPENAI_API_KEY=dummy                       # the local vLLM ignores auth -- any non-empty value works
OPENAI_BASE_URL=http://127.0.0.1:8001/v1   # SkyRL's in-process vLLM HTTP endpoint (host/port set by the run script)
LITELLM_MODEL_REGISTRY_PATH=configs/mini_swe_agent/litellm.json   # optional cost/context registry (repo-root-relative)
