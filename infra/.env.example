# mini-swe-agent-sandbox infra configuration.
#
# This is the committed source of truth for defaults. To customize, copy it to
# `.env` (which is gitignored) and edit there:
#
#     cp .env.example .env
#
# Precedence (highest first):  real environment  >  .env  >  .env.example
# So `PROJECT_ID=foo ./up.sh` and editing `.env` both override these values.
# Format is plain KEY=value (no quotes needed). Lines after `#` are comments.

# --- GCP project / location (all explicit; nothing is auto-detected) --------
PROJECT_ID=                        # REQUIRED — your GCP project id, e.g. my-team-sandbox
REGION=us-central1
ZONE=us-central1-a
CLUSTER_NAME=mini-swe-sandbox
RELEASE_CHANNEL=regular

# --- (1) default node pool --------------------------------------------------
DEFAULT_POOL_NAME=default-pool
DEFAULT_POOL_MACHINE=e2-standard-4
DEFAULT_POOL_NODES=1

# --- (2) KubeRay GPU node pool ----------------------------------------------
# Cheap single-L4 default (proves scheduling). For the real run:
#   GPU_MACHINE=a3-highgpu-8g  GPU_TYPE=nvidia-h100-80gb  GPU_PER_NODE=8
GPU_POOL_NAME=kuberay-gpu-pool
GPU_MACHINE=g2-standard-12
GPU_TYPE=nvidia-l4
GPU_PER_NODE=1
GPU_DRIVER_VERSION=default
GPU_POOL_MIN=0
GPU_POOL_MAX=2
# Set to 1 to skip the GPU pool (e.g. no GPU quota) and still build the rest.
SKIP_GPU_POOL=0
GPU_POOL_LABEL=workload=ray-gpu
GPU_POOL_TAINT=workload=ray-gpu:NoSchedule

# --- (3) agent-sandbox gVisor node pool -------------------------------------
SANDBOX_POOL_NAME=sandbox-gvisor-pool
SANDBOX_MACHINE=e2-standard-8
SANDBOX_POOL_MIN=1
SANDBOX_POOL_MAX=10
SANDBOX_POOL_LABEL=workload=sandbox

# --- (4) operators ----------------------------------------------------------
KUBERAY_VERSION=1.2.2
KUBERAY_NAMESPACE=kuberay-system
# agent-sandbox release tag; "latest" resolves to the newest GitHub release.
AGENT_SANDBOX_VERSION=latest
AGENT_SANDBOX_NAMESPACE=agent-sandbox-system
INSTALL_AGENT_SANDBOX_EXTENSIONS=true

# --- (optional) sample RayCluster -------------------------------------------
# When 1, up.sh also runs 07-deploy-raycluster.sh to apply the sample RayCluster
# (head on the default pool; worker group at 0 replicas, so no GPU on apply).
DEPLOY_RAYCLUSTER=0

# --- (5) workload identity (optional) ---------------------------------------
ENABLE_WORKLOAD_IDENTITY=true

# --- (6) RBAC ---------------------------------------------------------------
RAY_NAMESPACE=skyrl
SANDBOX_NAMESPACE=skyrl-sandboxes
SANDBOX_RUNNER_SA=skyrl-sandbox-runner
